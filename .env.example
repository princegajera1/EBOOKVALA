# Copy this file to .env and fill in real values
# Never commit .env to version control

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_SUPABASE_URL=https://your_project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
VITE_SECRET_ADMIN_TOKEN=choose_a_strong_password
VITE_ADMIN_PASSWORD=your_admin_password

# Transactional Email Config (Vercel Serverless Function & Resend API / Gmail SMTP)
RESEND_API_KEY=your_resend_api_key
EMAIL_TO=admin_recipient@example.com
EMAIL_FROM=Sender Name <onboarding@resend.dev>
GMAIL_USER=your_gmail_user@gmail.com
GMAIL_PASS=your_gmail_app_password

