rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to fetch the user's document inside /users/
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper functions to check roles
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }
    
    function isAuthor() {
      return isAuthenticated() && getUserData().role == 'author';
    }

    // 1. Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Users can write to their own user document, Admins can write anywhere
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
    
    // 2. Authors collection
    match /authors/{authorId} {
      allow read: if true; // Anyone can read author profiles
      // Authors can modify their own profile details, Admins can write anywhere
      allow write: if isAuthenticated() && (request.auth.uid == authorId || isAdmin());
    }
    
    // 3. Books collection
    match /books/{bookId} {
      allow read: if true; // Anyone can view the ebook catalog
      // Only admins or the book's assigned author can write/update
      allow write: if isAdmin() || (isAuthor() && request.resource.data.authorId == request.auth.uid);
    }
    
    // 4. Categories collection
    match /categories/{catId} {
      allow read: if true; // Public catalog access
      allow write: if isAdmin(); // Admin only
    }
    
    // 5. Reviews collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isAuthenticated(); // Authenticated users can post and reply to reviews
    }
    
    // 6. Orders collection
    match /orders/{orderId} {
      // Users can only view their own purchases; authors can inspect sales; admins see everything
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.readerId || request.auth.uid == resource.data.authorId || isAdmin());
      allow write: if isAuthenticated(); // Authenticated users can create orders (purchase)
    }
    
    // 7. Withdrawals collection
    match /withdrawals/{withId} {
      // Authors view their own requests, Admins inspect everything
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
      allow write: if isAuthenticated() && (isAuthor() || isAdmin());
    }
  }
}
